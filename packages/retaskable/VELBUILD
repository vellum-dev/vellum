maintainer="Jarett <jarett@reticulum.us>"
pkgname=retaskable
pkgver=1.0.3
pkgrel=0
upstream_author="jdkruzr"
category="utilities"
pkgdesc="CalDAV task client for reMarkable tablets"
url="https://github.com/jdkruzr/reTaskable"
arch="aarch64 armv7"
license="GPL-3.0-only"
depends="appload"
options="!check !fhs !strip !tracedeps"
subpackages="retaskable-capture:capture"
readmeurl="https://raw.githubusercontent.com/$upstream_author/reTaskable/v$pkgver/README.md"

source="$pkgname-$pkgver.tar.gz::https://github.com/$upstream_author/reTaskable/archive/refs/tags/v$pkgver.tar.gz"

image="ghcr.io/toltec-dev/rust:v4.0"

build() {
	apt-get update
	apt-get install -y --no-install-recommends qt6-base-dev
	ln -sf /usr/lib/qt6/libexec/rcc /usr/local/bin/rcc

	case "$CARCH" in
	aarch64)
		. /opt/x-tools/switch-aarch64.sh
		cd "$srcdir"/reTaskable-"$pkgver"/app
		./build-rmpp.sh
		;;
	armv7)
		. /opt/x-tools/switch-arm.sh
		cd "$srcdir"/reTaskable-"$pkgver"/app
		./build-rm.sh
		;;
	*)
		echo "Invalid CARCH: $CARCH"
		exit 1
		;;
	esac
}

package() {
	case "$CARCH" in
	aarch64) _output="output-rmpp" ;;
	armv7) _output="output-rm" ;;
	esac

	cd "$srcdir"/reTaskable-"$pkgver"
	install -Dm755 app/"$_output"/backend/entry \
		"$pkgdir"/home/root/xovi/exthome/appload/retaskable/backend/entry
	install -Dm644 app/"$_output"/resources.rcc \
		"$pkgdir"/home/root/xovi/exthome/appload/retaskable/resources.rcc
	install -Dm644 app/"$_output"/manifest.json \
		"$pkgdir"/home/root/xovi/exthome/appload/retaskable/manifest.json
	install -Dm644 app/"$_output"/icon.png \
		"$pkgdir"/home/root/xovi/exthome/appload/retaskable/icon.png

	install -Dm644 LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "$url" > "$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}

capture() {
	category="ui"
	pkgdesc="reTaskable note capture"
	depends="
	retaskable
	qt-resource-rebuilder
	qt-command-executor
	xovi-message-broker
	!convert-to-text-remover
	remarkable-os>=3.27
	"

	package() {
		cd "$srcdir"/reTaskable-"$pkgver"
		install -Dm644 app/xovi/retaskableSend.qmd \
			"$subpkgdir"/home/root/xovi/exthome/qt-resource-rebuilder/retaskableSend.qmd
		install -Dm644 app/xovi/retaskableJump.qmd \
			"$subpkgdir"/home/root/xovi/exthome/qt-resource-rebuilder/retaskableJump.qmd

		install -Dm644 LICENSE \
			"$subpkgdir"/home/root/.vellum/licenses/retaskable-capture/LICENSE
		echo "$url" > "$subpkgdir"/home/root/.vellum/licenses/retaskable-capture/SOURCES
	}
}

