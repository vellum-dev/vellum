maintainer="lhf <luis@lhf.pt>"
pkgname=dns2socks
pkgver=0.2.3
pkgrel=0
upstream_author="ssrlive"
category="utilities"
pkgdesc="A DNS server that forwards DNS requests to a SOCKS5 server."
url="https://github.com/tun2proxy/dns2socks"
arch="aarch64 armv7"
license="MIT"
options="!check !fhs !strip !tracedeps"
depends="mount-utils"

source="
https://github.com/tun2proxy/dns2socks/releases/download/v$pkgver/dns2socks-aarch64-unknown-linux-gnu.zip
https://github.com/tun2proxy/dns2socks/releases/download/v$pkgver/dns2socks-armv7-unknown-linux-gnueabihf.zip
https://raw.githubusercontent.com/tun2proxy/dns2socks/refs/tags/v$pkgver/LICENSE
dns2socks.defaults
dns2socks.service
"

unpack() {
	case "$CARCH" in
		aarch64)  unzip -o "$srcdir"/dns2socks-aarch64-unknown-linux-gnu.zip -d "$srcdir" ;;
		armv7)  unzip -o "$srcdir"/dns2socks-armv7-unknown-linux-gnueabihf.zip -d "$srcdir" ;;
	esac
}

package() {	
	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir/home/root/.vellum/licenses/$pkgname/LICENSE"
	
	install -Dm755 "$srcdir"/dns2socks \
		"$pkgdir"/home/root/.vellum/bin/dns2socks

	install -Dm644 "$srcdir"/dns2socks.defaults \
		"$pkgdir/home/root/.vellum/etc/default/dns2socks"
	install -Dm644 "$srcdir"/dns2socks.service \
		"$pkgdir/home/root/.vellum/share/dns2socks/systemd/dns2socks.service"
}

postinstall() {
	/home/root/.vellum/bin/mount-rw
	cp /home/root/.vellum/share/dns2socks/systemd/dns2socks.service /etc/systemd/system/
	systemctl daemon-reload
	/home/root/.vellum/bin/mount-restore

	systemctl enable --now dns2socks.service
}

postupgrade() {
	.vellum/hooks/post-install/dns2socks
	systemctl restart dns2socks.service
}

postosupgrade() {
	cp /home/root/.vellum/share/dns2socks/systemd/dns2socks.service /etc/systemd/system/dns2socks.service
	systemctl daemon-reload
	systemctl enable --now dns2socks.service
}

predeinstall() {
	systemctl disable --now dns2socks.service

	/home/root/.vellum/bin/mount-rw
	rm -f /etc/systemd/system/dns2socks.service
	systemctl daemon-reload
	/home/root/.vellum/bin/mount-restore
}

