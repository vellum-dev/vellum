maintainer="Mitchell Scott <mitchell@scottlabs.io>"
pkgname=stylus-remapper
pkgver=0.1.0
pkgrel=1
upstream_author="rmitchellscott"
category="utilities"
pkgdesc="Remaps stylus input events with configurable presets, pressure curves, and position offsets."
url="https://github.com/rmitchellscott/rm-stylus-remapper"
arch="aarch64 armv7"
license="GPL-3.0-only"
depends="xovi-extensions"
options="!check !fhs !strip !tracedeps"
donateurl="https://buymeacoffee.com/rmitchellscott"
readmeurl="https://raw.githubusercontent.com/$upstream_author/rm-stylus-remapper/v$pkgver/README.md"
source="
https://github.com/$upstream_author/rm-stylus-remapper/releases/download/v$pkgver/stylus-remapper-aarch64.tar.gz
https://github.com/$upstream_author/rm-stylus-remapper/releases/download/v$pkgver/stylus-remapper-armv7.tar.gz
https://github.com/$upstream_author/rm-stylus-remapper/releases/download/v$pkgver/stylusRemapperSettings.qmd
https://raw.githubusercontent.com/$upstream_author/rm-stylus-remapper/v$pkgver/LICENSE
"

package() {
	local bin
	case "$CARCH" in
	aarch64) bin="stylus-remapper-aarch64" ;;
	armv7) bin="stylus-remapper-armv7" ;;
	esac

	install -Dm755 "$srcdir"/$bin \
		"$pkgdir"/home/root/.vellum/bin/stylus-remapper

	install -d "$pkgdir"/home/root/xovi/exthome/qt-resource-rebuilder
	install -Dm644 "$srcdir"/stylusRemapperSettings.qmd \
		"$pkgdir"/home/root/xovi/exthome/qt-resource-rebuilder/stylusRemapperSettings.qmd

	install -d "$pkgdir"/home/root/xovi/scripts/pre-start
	install -d "$pkgdir"/home/root/xovi/scripts/pre-stock

	cat > "$pkgdir"/home/root/xovi/scripts/pre-start/stylus-remapper.sh << 'SCRIPT'
#!/bin/bash
killall stylus-remapper 2>/dev/null
/home/root/.vellum/bin/stylus-remapper &
SCRIPT
	chmod 755 "$pkgdir"/home/root/xovi/scripts/pre-start/stylus-remapper.sh

	cat > "$pkgdir"/home/root/xovi/scripts/pre-stock/stylus-remapper.sh << 'SCRIPT'
#!/bin/bash
killall stylus-remapper 2>/dev/null
SCRIPT
	chmod 755 "$pkgdir"/home/root/xovi/scripts/pre-stock/stylus-remapper.sh

	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "https://github.com/$upstream_author/rm-stylus-remapper/archive/refs/tags/v$pkgver.tar.gz" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}

predeinstall() {
	killall stylus-remapper 2>/dev/null
}

