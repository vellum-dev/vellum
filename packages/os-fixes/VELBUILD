maintainer="Nathaniel van Diepen <eeems@eeems.email>"
pkgname=os-fixes
pkgver=0.1
pkgrel=0
pkgdesc="Fix systemd service startup issues on some devices"
upstream_author="vellum-dev"
category="fixes"
url="https://vellum.delivery/"
arch="aarch64 armv7"
license="MIT"
depends="!rmppm !rmppure !rm2 remarkable-os>=3.27.1.0"
options="!check !fhs !strip !tracedeps"
source="
service-overrides.conf
"
replaces="rmpp-fixes"

package() {
	install -Dm644 "$srcdir"/service-overrides.conf \
		"$pkgdir"/home/root/.vellum/share/os-fixes/service-overrides.conf
}
postinstall() {
	if [ "$SKIP_SYSTEMD_HANDLING" != "1" ]; then
		/home/root/.vellum/bin/mount-rw
		cp /home/root/.vellum/share/os-fixes/service-overrides.conf \
			/etc/systemd/system/systemd-logind.service.d/override.conf
		cp /home/root/.vellum/share/os-fixes/service-overrides.conf \
			/etc/systemd/system/systemd-resolved.service.d/override.conf
		cp /home/root/.vellum/share/os-fixes/service-overrides.conf \
			/etc/systemd/system/systemd-timedated.service.d/override.conf
		cp /home/root/.vellum/share/os-fixes/service-overrides.conf \
			/etc/systemd/system/chronyd.service.d/override.conf
		systemctl daemon-reload
		systemctl reset-failed \
			systemd-logind \
			systemd-resolved \
			systemd-timedated \
			chronyd
		systemctl restart \
			systemd-logind \
			systemd-resolved \
			systemd-timedated \
			chronyd
		/home/root/.vellum/bin/mount-restore
	fi
}
postupgrade() {
	postinstall
}
postosupgrade() {
	if [ "$SKIP_SYSTEMD_HANDLING" != "1" ]; then
		cp /home/root/.vellum/share/os-fixes/service-overrides.conf \
			/etc/systemd/system/systemd-logind.service.d/override.conf
		cp /home/root/.vellum/share/os-fixes/service-overrides.conf \
			/etc/systemd/system/systemd-resolved.service.d/override.conf
		cp /home/root/.vellum/share/os-fixes/service-overrides.conf \
			/etc/systemd/system/systemd-timedated.service.d/override.conf
		cp /home/root/.vellum/share/os-fixes/service-overrides.conf \
			/etc/systemd/system/chronyd.service.d/override.conf
		systemctl daemon-reload
		systemctl reset-failed \
			systemd-logind \
			systemd-resolved \
			systemd-timedated \
			chronyd
		systemctl restart \
			systemd-logind \
			systemd-resolved \
			systemd-timedated \
			chronyd
	fi
}
predeinstall() {
	rm -f \
		/etc/systemd/system/systemd-logind.service.d/override.conf \
		/etc/systemd/system/systemd-resolved.service.d/override.conf \
		/etc/systemd/system/systemd-timedated.service.d/override.conf \
		/etc/systemd/system/chronyd.service.d/override.conf
	systemctl daemon-reload
}
