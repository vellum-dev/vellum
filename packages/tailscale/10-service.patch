Author: shellhazard <10951745+shellhazard@users.noreply.github.com>
Summary: Patches the service file to use the appropriate paths and ensures it starts after home is mounted.
----
--- a/systemd/tailscaled.service
+++ b/systemd/tailscaled.service
@@ -2,12 +2,13 @@
 Description=Tailscale node agent
 Documentation=https://tailscale.com/kb/
 Wants=network-pre.target
-After=network-pre.target NetworkManager.service systemd-resolved.service
+After=network-pre.target NetworkManager.service systemd-resolved.service home.mount
+Requires=home.mount
 
 [Service]
-EnvironmentFile=/etc/default/tailscaled
-ExecStart=/usr/sbin/tailscaled --state=/var/lib/tailscale/tailscaled.state --socket=/run/tailscale/tailscaled.sock --port=${PORT} $FLAGS
-ExecStopPost=/usr/sbin/tailscaled --cleanup
+EnvironmentFile=/home/root/.vellum/etc/default/tailscaled
+ExecStart=/home/root/.vellum/bin/tailscaled --state=/home/root/.local/var/lib/tailscale/tailscaled.state --socket=/run/tailscale/tailscaled.sock --port=${PORT} $FLAGS
+ExecStopPost=/home/root/.vellum/bin/tailscaled --cleanup
 
 Restart=on-failure
 
