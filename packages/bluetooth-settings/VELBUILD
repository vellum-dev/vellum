options='strip tracedeps'

package() {
	install -Dm644 "$srcdir"/bluetoothSettings.qmd \
		"$pkgdir"/home/root/xovi/exthome/qt-resource-rebuilder/bluetoothSettings.qmd

	install -Dm644 "$srcdir"/bluetooth.rcc \
		"$pkgdir"/home/root/xovi/exthome/qt-resource-rebuilder/bluetooth.rcc

	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "https://github.com/rmitchellscott/xovi-bluetoothsettings" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}
