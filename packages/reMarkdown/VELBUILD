source="
reMarkdown-$pkgver.tar.gz::https://github.com/$upstream_author/reMarkdown/archive/refs/tags/v$pkgver.tar.gz
"

image() {
	case "$CARCH" in
	aarch64) echo "eeems/remarkable-toolchain:5.6.75-rmpp" ;;
	armv7) echo "eeems/remarkable-toolchain:5.6.75-rm1" ;;
	*)
		echo "Invalid CARCH: $CARCH"
		exit 1
		;;
	esac
}

build() {
	set -e
	apt-get update
	apt-get install -y golang-go

	cd "$srcdir"/reMarkdown-"$pkgver"
	. "$(find /opt/codex -name 'environment-setup-*' -type f | head -n1)"
	case "$CARCH" in
	aarch64) arch=arm64 ;;
	armv7) arch=armv7h ;;
	*)
		echo "Invalid CARCH: $CARCH"
		exit 1
		;;
	esac
	PATH="${OECORE_NATIVE_SYSROOT}/usr/libexec:$PATH" \
		bash -e ./build.sh "$arch"
	"$STRIP" --strip-unneeded rmd/backend/entry
}

