maintainer="Nathaniel van Diepen <eeems@eeems.email>"
pkgname=puzzles
pkgver=0.2.4
pkgrel=0
pkgdesc="Simon Tatham's Puzzle Package"
upstream_author="mrichards42"
category="apps"
url="https://github.com/mrichards42/remarkable_puzzles"
arch="armv7 aarch64"
license="GPL-2.0-only"
readmeurl="https://raw.githubusercontent.com/$upstream_author/remarkable_puzzles/v$pkgver/README.md"
source="
https://github.com/$upstream_author/remarkable_puzzles/releases/download/v$pkgver/puzzles-source.tar.gz
rmkit.zip::https://github.com/rmkit-dev/rmkit/archive/fc372b29c6f19e4da645277e1902255e3198b59f.zip
external.manifest.json
"
options="!check !fhs !strip !tracedeps"

image="ghcr.io/toltec-dev/python:v4.0"
build() {
	set -e
	cd "$srcdir/$pkgname-source"
	case "$CARCH" in
	aarch64) . /opt/x-tools/switch-aarch64.sh ;;
	armv7) . /opt/x-tools/switch-arm.sh ;;
	*)
		echo "Invalid CARCH: $CARCH"
		exit 1
		;;
	esac
	export CXX="${CROSS_COMPILE}g++"
	python3 -m pip install --break-system-packages okp
	sed -i 's|arm-linux-gnueabihf-|${CROSS_COMPILE}|' defs.mk
	rm -rf vendor/rmkit
	ln -s "$srcdir"/rmkit-fc372b29c6f19e4da645277e1902255e3198b59f vendor/rmkit
	sed -ri 's|pointer_size\)|pointer_size*)|' \
		vendor/rmkit/src/rmkit/fb/fb.cpy
	sed -i 's|/opt/etc/puzzles|/home/root/xovi/exthome/appload/puzzles|' \
		src/paths.hpp
	CROSS_TC=${CROSS_COMPILE%-} \
	ARCH=rm \
	BUILD=release \
	RMP_VERSION="$pkgver" \
	make puzzles
}

package() {
	cd "$srcdir/$pkgname-source"
	install -Dm644 "LICENSE" \
		"$pkgdir/home/root/.vellum/licenses/$pkgname/LICENSE"
	echo "https://github.com/$upstream_author/remarkable_puzzles" > \
		"$pkgdir/home/root/.vellum/licenses/$pkgname/SOURCES"

	install -Dm755 build/release/puzzles \
		"$pkgdir"/home/root/xovi/exthome/appload/puzzles/puzzles
	install -Dm644 config/* \
		-t "$pkgdir"/home/root/xovi/exthome/appload/puzzles/
	install -Dm644 help/* \
		-t "$pkgdir"/home/root/xovi/exthome/appload/puzzles/help
	install -Dm644 icons/* \
		-t "$pkgdir"/home/root/xovi/exthome/appload/puzzles/icons
	install -Dm644 "$startdir"/external.manifest.json \
		"$pkgdir"/home/root/xovi/exthome/appload/puzzles/external.manifest.json
}
