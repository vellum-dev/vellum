pkgname=vnzee
pkgver=0.1.0
pkgrel=0
upstream_author="Interloper"
category="apps"
pkgdesc="A minimal VNC client for reMarkable devices"
url="https://github.com/0xdeb7ef/vnzee"
license="GPL-2.0"
arch="aarch64 armv7"
depends="appload"
options="!check !fhs !strip !tracedeps"

source="
https://github.com/0xdeb7ef/vnzee/releases/download/v$pkgver/aarch64.tar.gz
https://github.com/0xdeb7ef/vnzee/releases/download/v$pkgver/armv7.tar.gz
https://raw.githubusercontent.com/0xdeb7ef/vnzee/master/LICENSE
"

unpack() {
	tar -C "$srcdir" -zxf "$srcdir/$CARCH.tar.gz"
}

package() {
	install -Dm755 "$srcdir"/vnzee \
		"$pkgdir"/home/root/xovi/exthome/appload/$pkgname/vnzee
	install -Dm644 "$srcdir"/external.manifest.json \
		"$pkgdir"/home/root/xovi/exthome/appload/$pkgname/external.manifest.json

	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "https://github.com/0xdeb7ef/$pkgname/archive/v$pkgver.tar.gz" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}

postinstall() {
	echo ""
	echo "================================================================="
	echo "  NOTE: You have to update your connection parameters in"
	echo "   /home/root/xovi/exthome/appload/vnzee/external.manifest.json"
	echo "================================================================="
	echo ""
}

postupgrade() {
	echo ""
	echo "================================================================="
	echo "  NOTE: You have to update your connection parameters in"
	echo "   /home/root/xovi/exthome/appload/vnzee/external.manifest.json"
	echo "================================================================="
	echo ""
}

postdeinstall() {
	if [ "$VELLUM_PURGE" = "1" ]; then
		rm -rf \
			/home/root/xovi/exthome/appload/vnzee
	fi
}

