maintainer="Nathaniel van Diepen <eeems@eeems.email>"
pkgname=alpine-chroot-install
pkgver=0.14.0
pkgrel=0
pkgdesc="Install Alpine Linux in chroot with a breeze."
upstream_author="alpinelinux"
category="utilities"
url=https://github.com/$upstream_author/alpine-chroot-install
arch="noarch"
license="MIT"
readmeurl="https://raw.githubusercontent.com/$upstream_author/alpine-chroot-install/v$pkgver/README.adoc"
source="https://raw.githubusercontent.com/$upstream_author/alpine-chroot-install/v$pkgver/alpine-chroot-install"
options="!check !fhs !strip !tracedeps"
package() {
	cd "$srcdir"/"$pkgname"-"$pkgver"
	sed -i 's|/usr/sbin|/bin|' Makefile
	make DESTDIR="$pkgdir"/home/root/.vellum/ install
	sed -i 's|alpine-chroot-install_DIR=/usr/share/alpine-chroot-install|alpine-chroot-install_DIR=/home/root/.vellum/usr/share/alpine-chroot-install|' \
		"$pkgdir"/home/root/.vellum/bin/alpine-chroot-install
	install -Dm644 debian/copyright \
		"$pkgdir/home/root/.vellum/licenses/$pkgname/LICENSE"
	echo "https://github.com/$upstream_author/alpine-chroot-install" > \
		"$pkgdir/home/root/.vellum/licenses/$pkgname/SOURCES"
}
