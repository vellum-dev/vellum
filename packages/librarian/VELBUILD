donateurl="https://buymeacoffee.com/rmitchellscott"
source="
https://github.com/$upstream_author/rm-librarian/releases/download/v$pkgver/librarian-aarch64.so
https://github.com/$upstream_author/rm-librarian/releases/download/v$pkgver/librarian-armv7.so
https://raw.githubusercontent.com/$upstream_author/rm-librarian/v$pkgver/LICENSE
"

package() {
	local so_file
	case "$CARCH" in
	aarch64) so_file="librarian-aarch64.so" ;;
	armv7) so_file="librarian-armv7.so" ;;
	esac

	install -Dm644 "$srcdir"/$so_file \
		"$pkgdir"/home/root/xovi/extensions.d/librarian.so

	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "https://github.com/rmitchellscott/rm-librarian/archive/refs/tags/v$pkgver.tar.gz" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}
