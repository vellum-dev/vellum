maintainer="Mitchell Scott <mitchell@scottlabs.io>"
pkgname=librarian
pkgver=0.3.1
pkgrel=0
upstream_author="rmitchellscott"
category="framework"
pkgdesc="Document library management extension"
url="https://github.com/rmitchellscott/rm-librarian"
arch="aarch64 armv7"
license="GPL-3.0-or-later"
depends="xovi-message-broker>=18 xovi-message-broker<19"
options="!check !fhs !strip !tracedeps"
source="
https://github.com/rmitchellscott/rm-librarian/releases/download/v$pkgver/librarian-aarch64.so
https://github.com/rmitchellscott/rm-librarian/releases/download/v$pkgver/librarian-armv7.so
https://raw.githubusercontent.com/rmitchellscott/rm-librarian/main/LICENSE
"

package() {
	local so_file
	case "$CARCH" in
		aarch64) so_file="librarian-aarch64.so" ;;
		armv7) so_file="librarian-armv7.so" ;;
	esac

	install -Dm644 "$srcdir"/$so_file \
		"$pkgdir"/home/root/xovi/extensions.d/librarian.so

	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "https://github.com/rmitchellscott/rm-librarian/archive/refs/tags/v$pkgver.tar.gz" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}
