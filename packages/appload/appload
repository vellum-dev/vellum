#!/bin/bash
set -e
case "$1" in
is-active)
    pid=$(systemctl show --property MainPID --value xochitl.service)
    if [ "$pid" -eq 0 ]; then
        exit 1
    fi
    cat /proc/"$pid"/environ | tr '\0' '\n' | grep LD_PRELOAD | grep -q xovi.so
    ;;
is-enabled | enable | disable | paused | running)
    ;;
logs)
    if [ $# -eq 2 ] && [[ "$2" == "-f" ]] || [[ "$2" == "--follow" ]]; then
        journalctl --follow --all --unit xochitl.service
    else
        journalctl --no-pager --all --unit xochitl.service
    fi
    ;;
start)
    /home/root/xovi/start
    ;;
stop)
    systemctl stop xochitl.service
    if mountpoint -q /etc/systemd/system/xochitl.service.d; then
        umount -q /etc/systemd/system/xochitl.service.d
    fi
    /home/root/xovi/scripts/pre-stock/launcherctl.prestock.sh
    systemctl daemon-reload
    ;;
apps)
    find /home/root/xovi/exthome/appload -name external.manifest.json |
        /usr/bin/xargs -n1 /usr/bin/dirname |
        xargs -n1 /usr/bin/basename
    find /home/root/xovi/exthome/appload -name manifest.json |
        /usr/bin/xargs -n1 /usr/bin/dirname |
        xargs -n1 /usr/bin/basename
    ;;
*)
    echo "Xovi does not support this method"
    exit 1
    ;;
esac
