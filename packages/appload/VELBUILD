maintainer="Mitchell Scott <mitchell@scottlabs.io>"
pkgname=appload
pkgver=0.5.0
pkgrel=0
upstream_author="asivery"
category="framework"
pkgdesc="XOVI extension for windowed and fullscreen apps"
url="https://github.com/asivery/rm-appload"
arch="aarch64 armv7"
license="GPL-3.0"
depends="qt-resource-rebuilder remarkable-os>=3.22 remarkable-os<3.26"
options="!check !fhs !strip !tracedeps"

source="
https://github.com/asivery/rm-appload/releases/download/v$pkgver/appload-aarch64.zip
https://github.com/asivery/rm-appload/releases/download/v$pkgver/appload-arm32.zip
https://raw.githubusercontent.com/asivery/rm-appload/master/LICENSE
"


unpack() {
	case "$CARCH" in
		aarch64) unzip -o "$srcdir"/appload-aarch64.zip -d "$srcdir" ;;
		armv7) unzip -o "$srcdir"/appload-arm32.zip -d "$srcdir" ;;
	esac
}

package() {
	install -Dm644 "$srcdir"/appload.so \
		"$pkgdir"/home/root/xovi/extensions.d/appload.so

	install -Dm644 "$srcdir"/shims/qtfb-shim.so \
		"$pkgdir"/home/root/shims/qtfb-shim.so
	install -Dm644 "$srcdir"/shims/qtfb-shim-32bit.so \
		"$pkgdir"/home/root/shims/qtfb-shim-32bit.so

	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "https://github.com/asivery/rm-appload/archive/v$pkgver.tar.gz" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}

