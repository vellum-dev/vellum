subpackages='
launcherctl-appload:launcherctl_appload
'
maintainer="Mitchell Scott <mitchell@scottlabs.io>"
pkgname=appload
pkgver=0.5.3
pkgrel=1
upstream_author="asivery"
category="launchers"
pkgdesc="XOVI extension for windowed and fullscreen apps"
url="https://github.com/asivery/rm-appload"
arch="aarch64 armv7"
license="GPL-3.0"
depends="qt-resource-rebuilder remarkable-os>=3.26 remarkable-os<3.28"
readmeurl="https://raw.githubusercontent.com/$upstream_author/rm-appload/v$pkgver/README.MD"
donateurl="https://ko-fi.com/asivery"
source="
https://github.com/$upstream_author/rm-appload/releases/download/v$pkgver/appload-aarch64.zip
https://github.com/$upstream_author/rm-appload/releases/download/v$pkgver/appload-arm32.zip
https://raw.githubusercontent.com/$upstream_author/rm-appload/v$pkgver/LICENSE
appload
launcherctl.LICENSE
launcherctl.prestart.sh
launcherctl.poststock.sh
"

unpack() {
	case "$CARCH" in
	aarch64) unzip -o "$srcdir"/appload-aarch64.zip -d "$srcdir" ;;
	armv7) unzip -o "$srcdir"/appload-arm32.zip -d "$srcdir" ;;
	esac
}

package() {
	install -Dm644 "$srcdir"/appload.so \
		"$pkgdir"/home/root/xovi/extensions.d/appload.so

	install -Dm644 "$srcdir"/shims/qtfb-shim.so \
		"$pkgdir"/home/root/shims/qtfb-shim.so
	install -Dm644 "$srcdir"/shims/qtfb-shim-32bit.so \
		"$pkgdir"/home/root/shims/qtfb-shim-32bit.so

	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "https://github.com/asivery/rm-appload/archive/v$pkgver.tar.gz" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}

launcherctl_appload() {
	pkgdesc="Launcherctl configuration for appload"
	category="utilities"
	license="MIT"
	depends="
    appload
    launcherctl
    "
	package() {
		install -o root -g root -Dm755 -t "$subpkgdir"/home/root/.vellum/share/launcherctl \
			"$srcdir/appload"
		install -o root -g root -Dm755 -t "$subpkgdir"/home/root/xovi/scripts/pre-start \
			"$srcdir/launcherctl.prestart.sh"
		install -o root -g root -Dm755 -t "$subpkgdir"/home/root/xovi/scripts/post-stock \
			"$srcdir/launcherctl.poststock.sh"
		install -Dm644 "$srcdir/launcherctl.LICENSE" \
			"$subpkgdir/home/root/.vellum/licenses/$subpkgname/LICENSE"
		echo "https://github.com/vellum-dev/vellum" > \
			"$subpkgdir/home/root/.vellum/licenses/$subpkgname/SOURCES"
	}

	predeinstall() {
		set -e
		if [[ "$(/home/root/.vellum/bin/launcherctl current-launcher)" == "appload" ]]; then
			/home/root/.vellum/bin/launcherctl switch-launcher none
		fi
	}
}

