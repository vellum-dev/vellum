maintainer="Mitchell Scott <mitchell@scottlabs.io>"
pkgname=rmstream
pkgver=0.1.5
pkgrel=1
upstream_author="asivery"
category="apps"
pkgdesc="Stream your reMarkable's screen to any device on the local network via HTTP"
url="https://github.com/asivery/appload-rmstream"
arch="aarch64 armv7"
license="GPL-3.0"
depends="appload framebuffer-spy>=18.0.0 framebuffer-spy<20.0.0 xovi-message-broker>=18.0.0 xovi-message-broker<20.0.0"
readmeurl="https://raw.githubusercontent.com/$upstream_author/appload-rmstream/v$pkgver/README.MD"
donateurl="https://ko-fi.com/asivery"

source="
https://github.com/$upstream_author/appload-rmstream/releases/download/v$pkgver/rmstream-aarch64.tar.gz
https://github.com/$upstream_author/appload-rmstream/releases/download/v$pkgver/rmstream-arm32.tar.gz
https://raw.githubusercontent.com/$upstream_author/appload-rmstream/v$pkgver/LICENSE
"

unpack() {
	case "$CARCH" in
	aarch64) tar -xzf "$srcdir"/rmstream-aarch64.tar.gz -C "$srcdir" ;;
	armv7) tar -xzf "$srcdir"/rmstream-arm32.tar.gz -C "$srcdir" ;;
	esac
}

package() {
	install -d "$pkgdir"/home/root/xovi/exthome/appload
	cp -r "$srcdir"/rmstream \
		"$pkgdir"/home/root/xovi/exthome/appload/rmstream

	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "https://github.com/asivery/appload-rmstream/archive/v$pkgver.tar.gz" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}

