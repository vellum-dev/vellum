package() {
	install -Dm644 "$srcdir"/libepaper.so \
		"$pkgdir"/home/root/.vellum/lib/plugins/platforms/libepaper.so

	install -d "$pkgdir"/home/root/.vellum/licenses/$pkgname
	echo "https://github.com/$upstream_author/epaper-qpa" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}

