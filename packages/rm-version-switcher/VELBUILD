maintainer="Mitchell Scott <mitchell@scottlabs.io>"
pkgname=rm-version-switcher
pkgver=1.0.0
pkgrel=2
upstream_author="rmitchellscott"
category="utilities"
pkgdesc="Interactive CLI tool for switching between installed reMarkable OS versions"
url="https://github.com/rmitchellscott/rm-version-switcher"
arch="aarch64 armv7"
license="MIT"
options="!check !fhs !strip !tracedeps"
readmeurl="https://raw.githubusercontent.com/$upstream_author/rm-version-switcher/v$pkgver/README.md"

source="
https://github.com/$upstream_author/rm-version-switcher/releases/download/v$pkgver/rm-version-switcher-aarch64.tar.gz
https://github.com/$upstream_author/rm-version-switcher/releases/download/v$pkgver/rm-version-switcher-armv7.tar.gz
https://raw.githubusercontent.com/$upstream_author/rm-version-switcher/main/LICENSE
"

unpack() {
	case "$CARCH" in
	aarch64) tar -xzf "$srcdir"/rm-version-switcher-aarch64.tar.gz -C "$srcdir" ;;
	armv7) tar -xzf "$srcdir"/rm-version-switcher-armv7.tar.gz -C "$srcdir" ;;
	esac
}

package() {
	local bin_file
	case "$CARCH" in
	aarch64) bin_file="rm-version-switcher-aarch64" ;;
	armv7) bin_file="rm-version-switcher-armv7" ;;
	esac

	install -Dm755 "$srcdir"/$bin_file \
		"$pkgdir"/home/root/.vellum/bin/rm-version-switcher

	install -Dm644 "$srcdir"/LICENSE \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
	echo "https://github.com/rmitchellscott/rm-version-switcher/archive/refs/tags/v$pkgver.tar.gz" > \
		"$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}
